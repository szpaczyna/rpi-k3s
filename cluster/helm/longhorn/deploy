#!/bin/bash
set -euo pipefail

NAMESPACE="longhorn-system"
RELEASE_NAME="longhorn"
CHART="longhorn/longhorn"
VERSION="${1:?Usage: ./deploy <version>}"

# Add helm repo
helm repo add longhorn https://charts.longhorn.io 2>/dev/null || true
helm repo update

helm upgrade --install "${RELEASE_NAME}" "${CHART}" \
  --namespace "${NAMESPACE}" \
  --create-namespace \
  --values values.yaml \
  --version "${VERSION}"

kubectl apply -f <(sops -d ../../secrets/longhorn-auth.yaml) -n "${NAMESPACE}"
