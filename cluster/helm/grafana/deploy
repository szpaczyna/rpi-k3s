#!/bin/bash
set -euo pipefail

NAMESPACE="monitoring"
RELEASE_NAME="grafana"
CHART="grafana/grafana"
VERSION="10.3.0"

# Add helm repo
helm repo add grafana https://grafana.github.io/helm-charts 2>/dev/null || true
helm repo update

kubectl apply -f <(sops -d ../../secrets/grafana-admin-creds.yaml) -n "${NAMESPACE}"
kubectl apply -f <(sops -d ../../secrets/grafana-backup-secret.yaml) -n "${NAMESPACE}"
kubectl apply -f backup-cronjob.yaml -n "${NAMESPACE}"

helm upgrade --install "${RELEASE_NAME}" "${CHART}" \
  --namespace "${NAMESPACE}" \
  --create-namespace \
  --values values.yaml \
  --version "${VERSION}"
